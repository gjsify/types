    "description": "GJS TypeScript type definitions for Mtk-13, generated from library version 13.0.0",
    "type": "module",
    "module": "mtk-13.js",
    "main": "mtk-13.js",
    "exports": {
      "./ambient": {
        "types": "./mtk-13-ambient.d.ts",
        "import": "./mtk-13-ambient.js",
        "default": "./mtk-13-ambient.js"
      },
      "./import": {
        "types": "./mtk-13-import.d.ts",
        "import": "./mtk-13-import.js",
        "default": "./mtk-13-import.js"
      },
      "./mtk-13": {
        "types": "./mtk-13.d.ts",
        "import": "./mtk-13.js",
        "default": "./mtk-13.js"
      },
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "default": "./index.js"
      }
    },
    "scripts": {
      "test": "tsc --project tsconfig.json"
    },
    "dependencies": {
      "@girs/gjs": "4.0.0-beta.40",
      "@girs/cairo-1.0": "1.0.0-4.0.0-beta.40",
