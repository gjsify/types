    "module": "gtop-2.0.js",
    "main": "gtop-2.0.js",
    "exports": {
      "./ambient": {
        "types": "./gtop-2.0-ambient.d.ts",
        "import": "./gtop-2.0-ambient.js",
        "default": "./gtop-2.0-ambient.js"
      },
      "./import": {
        "types": "./gtop-2.0-import.d.ts",
        "import": "./gtop-2.0-import.js",
        "default": "./gtop-2.0-import.js"
      },
      "./gtop-2.0": {
        "types": "./gtop-2.0.d.ts",
        "import": "./gtop-2.0.js",
        "default": "./gtop-2.0.js"
      },
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "default": "./index.js"
      }
    },
    "scripts": {
      "test": "tsc --project tsconfig.json"
    },
    "dependencies": {
      "@girs/gjs": "4.0.0-beta.42",
