    "type": "module",
    "module": "mtk-15.js",
    "main": "mtk-15.js",
    "exports": {
      "./ambient": {
        "types": "./mtk-15-ambient.d.ts",
        "import": "./mtk-15-ambient.js",
        "default": "./mtk-15-ambient.js"
      },
      "./import": {
        "types": "./mtk-15-import.d.ts",
        "import": "./mtk-15-import.js",
        "default": "./mtk-15-import.js"
      },
      "./mtk-15": {
        "types": "./mtk-15.d.ts",
        "import": "./mtk-15.js",
        "default": "./mtk-15.js"
      },
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "default": "./index.js"
      }
    },
    "scripts": {
      "test": "tsc --project tsconfig.json"
    },
    "dependencies": {
      "@girs/gjs": "4.0.0-beta.40",
      "@girs/graphene-1.0": "1.0.0-4.0.0-beta.40",
