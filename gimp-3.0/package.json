    "module": "gimp-3.0.js",
    "main": "gimp-3.0.js",
    "exports": {
      "./ambient": {
        "types": "./gimp-3.0-ambient.d.ts",
        "import": "./gimp-3.0-ambient.js",
        "default": "./gimp-3.0-ambient.js"
      },
      "./import": {
        "types": "./gimp-3.0-import.d.ts",
        "import": "./gimp-3.0-import.js",
        "default": "./gimp-3.0-import.js"
      },
      "./gimp-3.0": {
        "types": "./gimp-3.0.d.ts",
        "import": "./gimp-3.0.js",
        "default": "./gimp-3.0.js"
      },
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "default": "./index.js"
      }
    },
    "scripts": {
      "test": "tsc --project tsconfig.json"
    },
