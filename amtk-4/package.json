{
    "name": "@girs/amtk-4",
    "version": "4.0.4",
    "libraryVersion": "4.0.0",
    "description": "GJS TypeScript type definitions for Amtk-4, generated from library version 4.0.0",
    "type": "module",
    "module": "amtk-4.js",
    "main": "amtk-4.js",
    "exports": {
      "./ambient": {
        "types": "./amtk-4-ambient.d.ts",
        "import": "./amtk-4-ambient.js",
        "default": "./amtk-4-ambient.js"
      },
      "./import": {
        "types": "./amtk-4-import.d.ts",
        "import": "./amtk-4-import.js",
        "default": "./amtk-4-import.js"
      },
      "./amtk-4": {
        "types": "./amtk-4.d.ts",
        "import": "./amtk-4.js",
        "default": "./amtk-4.js"
      },
      ".": {
        "types": "./index.d.ts",
        "import": "./index.js",
        "default": "./index.js"
      }
    },
    "scripts": {
      "test": "tsc --project tsconfig.json"
    },
    "dependencies": {
      "@girs/gjs": "^4.0.4",
      "@girs/gtk-3.0": "^4.0.4",
      "@girs/xlib-2.0": "^4.0.4",
      "@girs/gdk-3.0": "^4.0.4",
      "@girs/cairo-1.0": "^4.0.4",
      "@girs/gobject-2.0": "^4.0.4",
      "@girs/glib-2.0": "^4.0.4",
      "@girs/pango-1.0": "^4.0.4",
      "@girs/harfbuzz-0.0": "^4.0.4",
      "@girs/freetype2-2.0": "^4.0.4",
      "@girs/gio-2.0": "^4.0.4",
      "@girs/gmodule-2.0": "^4.0.4",
      "@girs/gdkpixbuf-2.0": "^4.0.4",
      "@girs/atk-1.0": "^4.0.4"    },
    "devDependencies": {
      "typescript": "*"
    },
    "keywords": ["Gir", "TypeScript", "types", "GObject-Introspection", "GJS", "Amtk-4"],
    "author": "ts-for-gir",
